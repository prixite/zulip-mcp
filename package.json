{
  "name": "zulip-mcp",
  "version": "0.1.0",
  "description": "MCP server for Zulip — interact with streams, messages, and direct messages via AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zulip-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "zulip",
    "ai",
    "claude",
    "model-context-protocol",
    "chatbot",
    "messaging"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/prixite/zulip-mcp.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.0.0",
    "zod": "^3.25.0",
    "zulip-js": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
